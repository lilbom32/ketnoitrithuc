# CLB Tri Thức – Environment Variables
# Copy to .env.local and fill in real values. Never commit .env.local.

# ─────────────────────────────────────────────────────────────
# Sentry (Error Tracking)
# Get from https://sentry.io/settings/projects/
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=sntrys_xxx
SENTRY_ORG=clb-tri-thuc
SENTRY_PROJECT=clb-website

# ─────────────────────────────────────────────────────────────
# Formspree (contact forms)
# Get form IDs from https://formspree.io/forms
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_FORMSPREE_CONTACT_ID=your_contact_form_id
NEXT_PUBLIC_FORMSPREE_NEWSLETTER_ID=your_newsletter_form_id

# ─────────────────────────────────────────────────────────────
# Supabase
# Get from https://app.supabase.com → Project Settings → API
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Server-only — never expose to client:
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─────────────────────────────────────────────────────────────
# VNPay
# ─────────────────────────────────────────────────────────────
VNPAY_TMN_CODE=your_tmn_code
VNPAY_HASH_SECRET=your_hash_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=https://clbtrithuc.vn/api/webhooks/vnpay

# ─────────────────────────────────────────────────────────────
# Stripe
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
